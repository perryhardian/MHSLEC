generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  STUDENT
  ADMIN
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum CategoryKind {
  DEFAULT
  CUSTOM
}

enum BudgetPeriod {
  MONTHLY
  WEEKLY
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum NotificationType {
  BUDGET_WARNING
  BUDGET_EXCEEDED
  SAVINGS_REMINDER
  MONTHLY_REPORT
  GENERAL
}

enum NotificationStatus {
  UNREAD
  READ
}

model User {
  id                       String                    @id @default(uuid())
  name                     String
  email                    String                    @unique
  passwordHash             String                    @map("password_hash")
  role                     UserRole                  @default(STUDENT)
  monthlyAllowance         Decimal?                  @map("monthly_allowance") @db.Decimal(14, 2)
  expectedDailySpend       Decimal?                  @map("expected_daily_spend") @db.Decimal(14, 2)
  timeSkipDays             Int                       @default(0) @map("time_skip_days")
  phoneNumber              String?                   @map("phone_number")
  university               String?
  createdAt                DateTime                  @default(now()) @map("created_at")
  updatedAt                DateTime                  @updatedAt @map("updated_at")
  categories               Category[]
  transactions             Transaction[]
  budgets                  Budget[]
  savingsGoals             SavingsGoal[]
  savingsContributions     SavingsContribution[]
  dailyExpenseSetting      DailyExpenseSetting?
  autoSavingsSettings      AutoSavingsSetting[]
  notifications            Notification[]
  refreshTokens            RefreshToken[]
  financialHealthSnapshots FinancialHealthSnapshot[]

  @@map("users")
}

model Category {
  id                   String                @id @default(uuid())
  userId               String?               @map("user_id")
  name                 String
  type                 TransactionType
  kind                 CategoryKind          @default(CUSTOM)
  icon                 String?
  color                String?
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  user                 User?                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions         Transaction[]
  budgets              Budget[]
  dailyExpenseSettings DailyExpenseSetting[]

  @@unique([userId, name, type])
  @@map("categories")
}

model Transaction {
  id                    String               @id @default(uuid())
  userId                String               @map("user_id")
  categoryId            String               @map("category_id")
  type                  TransactionType
  amount                Decimal              @db.Decimal(14, 2)
  title                 String
  description           String?
  transactionAt         DateTime             @map("transaction_at")
  attachmentUrl         String?              @map("attachment_url")
  dailyExpenseSettingId String?              @map("daily_expense_setting_id")
  generatedForDate      DateTime?            @map("generated_for_date")
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")
  user                  User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  category              Category             @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  dailyExpenseSetting   DailyExpenseSetting? @relation(fields: [dailyExpenseSettingId], references: [id], onDelete: SetNull)

  @@unique([dailyExpenseSettingId, generatedForDate])
  @@index([userId, transactionAt])
  @@index([categoryId])
  @@map("transactions")
}

model Budget {
  id          String       @id @default(uuid())
  userId      String       @map("user_id")
  categoryId  String?      @map("category_id")
  name        String
  period      BudgetPeriod @default(MONTHLY)
  limitAmount Decimal      @map("limit_amount") @db.Decimal(14, 2)
  startDate   DateTime     @map("start_date")
  endDate     DateTime     @map("end_date")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId, startDate, endDate])
  @@index([categoryId])
  @@map("budgets")
}

model SavingsGoal {
  id                  String                @id @default(uuid())
  userId              String                @map("user_id")
  name                String
  targetAmount        Decimal               @map("target_amount") @db.Decimal(14, 2)
  currentAmount       Decimal               @default(0) @map("current_amount") @db.Decimal(14, 2)
  targetDate          DateTime?             @map("target_date")
  status              GoalStatus            @default(ACTIVE)
  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @updatedAt @map("updated_at")
  user                User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  contributions       SavingsContribution[]
  autoSavingsSettings AutoSavingsSetting[]

  @@index([userId, status])
  @@map("savings_goals")
}

model SavingsContribution {
  id                   String              @id @default(uuid())
  userId               String              @map("user_id")
  savingsGoalId        String              @map("savings_goal_id")
  amount               Decimal             @db.Decimal(14, 2)
  note                 String?
  contributedAt        DateTime            @map("contributed_at")
  autoSavingsSettingId String?             @map("auto_savings_setting_id")
  generatedForDate     DateTime?           @map("generated_for_date")
  createdAt            DateTime            @default(now()) @map("created_at")
  user                 User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  savingsGoal          SavingsGoal         @relation(fields: [savingsGoalId], references: [id], onDelete: Cascade)
  autoSavingsSetting   AutoSavingsSetting? @relation(fields: [autoSavingsSettingId], references: [id], onDelete: SetNull)

  @@unique([autoSavingsSettingId, generatedForDate])
  @@index([userId, contributedAt])
  @@index([savingsGoalId])
  @@map("savings_contributions")
}

model DailyExpenseSetting {
  id           String        @id @default(uuid())
  userId       String        @unique @map("user_id")
  categoryId   String        @map("category_id")
  amount       Decimal       @db.Decimal(14, 2)
  title        String        @default("Kebutuhan harian")
  isActive     Boolean       @default(true) @map("is_active")
  startDate    DateTime      @map("start_date")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  category     Category      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  transactions Transaction[]

  @@index([categoryId])
  @@map("daily_expense_settings")
}

model AutoSavingsSetting {
  id            String                @id @default(uuid())
  userId        String                @map("user_id")
  savingsGoalId String                @map("savings_goal_id")
  amount        Decimal               @db.Decimal(14, 2)
  isActive      Boolean               @default(true) @map("is_active")
  startDate     DateTime              @map("start_date")
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")
  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  savingsGoal   SavingsGoal           @relation(fields: [savingsGoalId], references: [id], onDelete: Cascade)
  contributions SavingsContribution[]

  @@unique([userId, savingsGoalId])
  @@index([savingsGoalId])
  @@map("auto_savings_settings")
}

model Notification {
  id        String             @id @default(uuid())
  userId    String             @map("user_id")
  type      NotificationType
  status    NotificationStatus @default(UNREAD)
  title     String
  message   String
  sentAt    DateTime?          @map("sent_at")
  readAt    DateTime?          @map("read_at")
  createdAt DateTime           @default(now()) @map("created_at")
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("notifications")
}

model FinancialHealthSnapshot {
  id                  String   @id @default(uuid())
  userId              String   @map("user_id")
  score               Int
  month               Int
  year                Int
  totalIncome         Decimal  @map("total_income") @db.Decimal(14, 2)
  totalExpense        Decimal  @map("total_expense") @db.Decimal(14, 2)
  remainingMoney      Decimal  @map("remaining_money") @db.Decimal(14, 2)
  savingsProgressRate Decimal  @map("savings_progress_rate") @db.Decimal(5, 2)
  createdAt           DateTime @default(now()) @map("created_at")
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year])
  @@map("financial_health_snapshots")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}
